{
  "name": "liteparse-pdf-parser",
  "version": "0.4.1",
  "description": "Obsidian plugin that wraps LiteParse (by Run Llama / LlamaIndex) to parse PDFs inside Obsidian.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "liteparse",
    "pdf",
    "llamaindex"
  ],
  "author": "davadev",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/davadev/obsidian_liteparse.git"
  },
  "bugs": {
    "url": "https://github.com/davadev/obsidian_liteparse/issues"
  },
  "homepage": "https://github.com/davadev/obsidian_liteparse",
  "dependencies": {
    "@llamaindex/liteparse": "^1.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "0.21.5",
    "obsidian": "^1.5.7",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  }
}
